---
// src/components/pages/HomeContent.astro
import ContactForm from '../ContactForm.astro';

const { t, lang } = Astro.props;
const h  = t.hero;
const sp = t.servicesPreview;
const ab = t.about;
const servicesHref = lang === 'fr' ? '/services' : '/en/services';
const projectsHref = lang === 'fr' ? '/realisations' : '/en/projects';
---

<!-- ── HERO ───────────────────────────────────────── -->
<section class="hero">
  <div class="hero-inner">
    <p class="hero-label">{h.label}</p>
    <h1>
      {h.h1[0]}<br>
      {h.h1[1]}<br>
      <em>{h.h1[2]}</em>
    </h1>
    <p class="hero-sub">{h.sub}</p>
    <div class="hero-actions">
      <a href={projectsHref} class="btn-primary">{h.btn1}</a>
      <a href="#contact"     class="btn-ghost">{h.btn2}</a>
    </div>
  </div>
</section>

<!-- ── STATS ──────────────────────────────────────── -->
<div class="stats-strip">
  <div class="stats-strip-inner">
    {t.stats.map((s: any) => (
      <div class="stat-item">
        <div class="stat-num">{s.num}{s.sup && <sup>{s.sup}</sup>}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>
</div>

<!-- ── ABOUT ──────────────────────────────────────── -->
<section class="about">
  <div class="about-grid">
    <div class="about-left">
      <span class="label" style="display:block;margin-bottom:.75rem;">{ab.label}</span>
      <span class="gold-rule"></span>
      <h2>{ab.h2[0]}<br>{ab.h2[1]}</h2>
      <p>{ab.p1}</p>
      <p>{ab.p2}</p>
    </div>
    <div class="about-right">
      {ab.cards.map((c: any, i: number) => (
        <div class="about-card">
          <div class="about-card-num">0{i + 1}</div>
          <div>
            <div class="about-card-title">{c.title}</div>
            <div class="about-card-desc">{c.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── SERVICES PREVIEW ───────────────────────────── -->
<section class="services-preview">
  <div class="section-header">
    <div>
      <span class="label" style="display:block;margin-bottom:.5rem;">{sp.label}</span>
      <h2>{sp.h2[0]}<br>{sp.h2[1]}</h2>
    </div>
    <a href={servicesHref}>{sp.link}</a>
  </div>
  <div class="services-grid">
    {sp.items.map((s: any, i: number) => (
      <a href={servicesHref} class="service-card">
        <!-- Minimal SVG icon per service -->
        {i === 0 && (
          <svg class="service-icon" viewBox="0 0 32 32" fill="none">
            <path d="M16 4v4M16 24v4M4 16H8M24 16h4M8.5 8.5l2.8 2.8M20.7 20.7l2.8 2.8M8.5 23.5l2.8-2.8M20.7 11.3l2.8-2.8" stroke="#C8963A" stroke-width="1.2" stroke-linecap="round"/>
            <circle cx="16" cy="16" r="4" stroke="#18202E" stroke-width="1.2"/>
          </svg>
        )}
        {i === 1 && (
          <svg class="service-icon" viewBox="0 0 32 32" fill="none">
            <rect x="6" y="8" width="20" height="16" rx="1" stroke="#18202E" stroke-width="1.2"/>
            <path d="M6 12h20" stroke="#C8963A" stroke-width="1.2"/>
            <path d="M11 17h10M11 20h6" stroke="#18202E" stroke-width="1" stroke-linecap="round"/>
          </svg>
        )}
        {i === 2 && (
          <svg class="service-icon" viewBox="0 0 32 32" fill="none">
            <path d="M6 26L12 8l4 10 4-6 6 14" stroke="#18202E" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 26h20" stroke="#C8963A" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        )}
        <h3>{s.title}</h3>
        <p>{s.desc}</p>
      </a>
    ))}
  </div>
</section>

<!-- ── CONTACT ────────────────────────────────────── -->
<ContactForm t={t} variant="home" formName={`contact-home-${lang}`} />
