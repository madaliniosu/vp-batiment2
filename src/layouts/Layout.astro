---
// src/layouts/Layout.astro
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, lang = 'fr', t } = Astro.props;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="VP Bâtiment — Construction & Rénovation en Île-de-France. Électricité, peinture, enduit, rénovation complète." />
  <title>{title}</title>

  <!-- Canonical & hreflang -->
  <link rel="canonical" href={`https://vpbatiment.fr${Astro.url.pathname}`} />
  {lang === 'fr' && <link rel="alternate" hreflang="en" href={`https://vpbatiment.fr/en/`} />}
  {lang === 'en' && <link rel="alternate" hreflang="fr" href="https://vpbatiment.fr/" />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700&family=Barlow:wght@300;400;500&family=IBM+Plex+Mono:wght@300;400&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <Navbar lang={lang} t={t} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} t={t} />
</body>
</html>
